{
  "expo": {
    "name": "habit widget",
    "slug": "habit-widget",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/image.png",
    "scheme": "habitwidget",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/foreground.png",
        "backgroundImage": "./assets/images/background.png",
        "monochromeImage": "./assets/images/monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.habitwidget"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/image.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/foreground.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "fonts": [
            "./assets/fonts/Ionicons.ttf"
          ],
          "widgets": [
            {
              "name": "HabitFixed",
              "label": "Fixed Size Habit Widget",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "Habit tracker widget fixed size",
              "previewImage": "./assets/images/fixed-size.png",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "Habit",
              "label": "Resizeable Habit Widget",
              "minWidth": "120dp",
              "minHeight": "60dp",
              "targetCellWidth": 2,
              "targetCellHeight": 1,
              "description": "Habit tracker widget resizeable",
              "previewImage": "./assets/images/reziseable.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1866d571-1c3b-4f6c-88f8-5380e6045168"
      }
    },
    "owner": "egaputra"
  }
}
